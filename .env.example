# Puerto (Render lo asigna con PORT)
PORT=3000

# PostgreSQL — en Render usa la Internal Database URL del addon
DATABASE_URL=postgresql://user:password@localhost:5432/alahya_quince

# Secreto simple para panel admin de confirmaciones (cámbialo)
ADMIN_SECRET=alahya-admin-cambia-esto

# Fecha del evento (ISO) — se usa en countdown del servidor y fallback
EVENT_DATE=2026-08-15T18:00:00-04:00
